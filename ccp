   "source": [
    "boys_cols = [col for col in df.columns if \"boys\" in col.lower()]\n",
    "girls_cols = [col for col in df.columns if \"girls\" in col.lower()]\n",
    "df['total_boys'] = df[boys_cols].sum(axis=1)\n",
    "df['total_girls'] = df[girls_cols].sum(axis=1)\n",
    "\n",
    "df['total_students'] = df['total_boys'] + df['total_girls']\n",
    "\n",
    "# Gender ratio\n",
    "df['gender_ratio'] = df['total_girls'] / (df['total_boys'] + 1)\n",
    "\n",
    "print(\"\\nFeature Engineering Done\")"
   ]
